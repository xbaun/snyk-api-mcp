{
  "name": "@xbaun/snyk-api-mcp",
  "version": "0.0.0-development",
  "description": "MCP server exposing Snyk REST discovery/detail flows plus V1 path analysis for AI coding agents.",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "snyk-api-mcp": "build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm exec tsc",
    "build:layout-archive": "node scripts/build-layout-archive.mjs",
    "dev": "pnpm exec tsx src/index.ts",
    "start": "node build/index.js",
    "lint": "pnpm exec eslint .",
    "lint:fix": "pnpm exec eslint . --fix",
    "gen:snyk-rest": "pnpm exec openapi-typescript https://api.snyk.io/rest/openapi/2026-03-25 -o src/snyk/types/snyk-rest.d.ts",
    "gen:snyk-api-v1": "pnpm exec openapi-typescript specs/snyk_v1-api-spec.yaml -o src/snyk/types/snyk-api-v1-types.d.ts",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xbaun/snyk-api-mcp.git"
  },
  "license": "ISC",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "openapi-fetch": "^0.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:tooling",
    "@commitlint/config-conventional": "catalog:tooling",
    "@commitlint/types": "catalog:tooling",
    "@eslint/js": "catalog:eslint",
    "@semantic-release/npm": "catalog:tooling",
    "@types/node": "catalog:types",
    "eslint": "catalog:eslint",
    "eslint-config-prettier": "catalog:eslint",
    "eslint-plugin-only-warn": "catalog:eslint",
    "eslint-plugin-prettier": "catalog:eslint",
    "eslint-plugin-simple-import-sort": "catalog:eslint",
    "eslint-plugin-turbo": "catalog:eslint",
    "eslint-plugin-unused-imports": "catalog:eslint",
    "husky": "catalog:tooling",
    "lint-staged": "catalog:tooling",
    "openapi-typescript": "catalog:tooling",
    "prettier": "catalog:eslint",
    "semantic-release": "catalog:tooling",
    "tsx": "catalog:tooling",
    "typescript": "catalog:tooling",
    "typescript-eslint": "catalog:eslint"
  }
}
