{
  "name": "@xbaun/snyk-api-mcp",
  "version": "0.0.0-development",
  "description": "MCP server exposing the Snyk REST API as tools for AI coding agents.",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "snyk-api-mcp": "build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm exec tsx src/index.ts",
    "start": "node build/index.js",
    "lint": "pnpm exec eslint .",
    "lint:fix": "pnpm exec eslint . --fix",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:tooling",
    "@commitlint/config-conventional": "catalog:tooling",
    "@commitlint/types": "catalog:tooling",
    "@eslint/js": "catalog:eslint",
    "@semantic-release/npm": "catalog:tooling",
    "@types/node": "catalog:types",
    "eslint": "catalog:eslint",
    "eslint-config-prettier": "catalog:eslint",
    "eslint-plugin-only-warn": "catalog:eslint",
    "eslint-plugin-prettier": "catalog:eslint",
    "eslint-plugin-simple-import-sort": "catalog:eslint",
    "eslint-plugin-turbo": "catalog:eslint",
    "eslint-plugin-unused-imports": "catalog:eslint",
    "husky": "catalog:tooling",
    "lint-staged": "catalog:tooling",
    "prettier": "catalog:eslint",
    "semantic-release": "catalog:tooling",
    "tsx": "catalog:tooling",
    "typescript": "catalog:tooling",
    "typescript-eslint": "catalog:eslint"
  }
}
