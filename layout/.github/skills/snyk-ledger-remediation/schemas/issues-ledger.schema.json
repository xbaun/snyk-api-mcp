{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xbaun.local/snyk-ledger-remediation/issues-ledger.schema.json",
  "title": "issues-ledger",
  "type": "object",
  "additionalProperties": false,
  "required": ["sessionId", "advisories"],
  "properties": {
    "$schema": { "type": "string" },
    "sessionId": { "type": "string", "minLength": 1 },
    "advisories": {
      "type": "array",
      "items": { "$ref": "#/$defs/advisory" }
    }
  },
  "$defs": {
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "issueType": {
      "type": "string",
      "enum": ["package_vulnerability", "code"]
    },
    "status": {
      "type": "string",
      "enum": ["not-started", "in-progress", "resolved", "blocked", "partially-resolved"]
    },
    "verificationState": {
      "type": "string",
      "enum": ["pass", "fail", "not-run"]
    },
    "overridePreflight": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "materializationPresent",
        "queryPackage",
        "matchingCaseKeys",
        "selectorConflict",
        "disposition"
      ],
      "properties": {
        "materializationPresent": { "type": "boolean" },
        "queryPackage": { "type": "string", "minLength": 1 },
        "matchingCaseKeys": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "selectorConflict": {
          "type": "string",
          "enum": ["none", "exact-selector", "same-package"]
        },
        "disposition": {
          "type": "string",
          "enum": ["reuse-existing-case", "create-new-case"]
        }
      }
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "filesChanged": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "dependencyUpdates": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "parentUpdates": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "overridesApplied": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "overridePreflight": {
          "$ref": "#/$defs/overridePreflight"
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dependencyCheck": { "type": "string", "enum": ["pass", "fail"] },
        "lint": { "$ref": "#/$defs/verificationState" },
        "typecheck": { "$ref": "#/$defs/verificationState" },
        "tests": { "$ref": "#/$defs/verificationState" },
        "build": { "$ref": "#/$defs/verificationState" }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "result": { "type": "string", "enum": ["resolved", "blocked", "partially-resolved"] },
        "summary": { "type": "string", "minLength": 1 },
        "blockers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "remediationProposal": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 }
      },
      "required": ["summary"]
    },
    "advisory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "advisoryKey",
        "title",
        "severity",
        "issueType",
        "riskScoreMax",
        "issueCount",
        "affectedProjectCount",
        "affectedProjectIds",
        "affectedWorkspacePackages",
        "createdAt",
        "status"
      ],
      "properties": {
        "advisoryKey": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "severity": { "$ref": "#/$defs/severity" },
        "issueType": { "$ref": "#/$defs/issueType" },
        "riskScoreMax": { "type": "number" },
        "issueCount": { "type": "integer", "minimum": 1 },
        "affectedProjectCount": { "type": "integer", "minimum": 1 },
        "affectedProjectIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "affectedWorkspacePackages": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "packageName": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/$defs/status" },
        "startedAt": { "type": "string", "format": "date-time" },
        "lastAttemptAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "lastFailureKind": {
          "type": "string",
          "enum": [
            "handback-parse",
            "handback-format",
            "override-validation",
            "code-health-validation",
            "resolver-error",
            "dirty-stop",
            "other"
          ]
        },
        "lastFailureAt": { "type": "string", "format": "date-time" },
        "lastFailureMessage": { "type": "string", "minLength": 1 },
        "vulnerablePackage": { "type": "string", "minLength": 1 },
        "vulnerableVersions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "targetVersion": { "type": "string", "minLength": 1 },
        "strategy": {
          "type": "string",
          "enum": ["update-direct", "update-parent", "consolidated-shared-upgrade", "temp-override"]
        },
        "riskLevel": { "type": "string", "enum": ["low", "medium", "high"] },
        "complexity": {
          "type": "string",
          "enum": ["trivial", "contained", "architectural", "false-positive"]
        },
        "filePath": { "type": "string", "minLength": 1 },
        "lineRange": { "type": "string", "minLength": 1 },
        "cweId": { "type": "string", "minLength": 1 },
        "implementation": { "$ref": "#/$defs/implementation" },
        "verification": { "$ref": "#/$defs/verification" },
        "outcome": { "$ref": "#/$defs/outcome" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "issueType": { "const": "package_vulnerability" } },
            "required": ["issueType"]
          },
          "then": {
            "properties": {
              "packageName": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "if": {
            "properties": {
              "issueType": { "const": "code" }
            },
            "required": ["issueType"]
          },
          "then": {
            "properties": {
              "status": {
                "type": "string",
                "enum": ["not-started", "in-progress", "resolved", "blocked"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "issueType": { "const": "package_vulnerability" },
              "status": { "enum": ["resolved", "blocked", "partially-resolved"] }
            },
            "required": ["issueType", "status"]
          },
          "then": {
            "required": [
              "vulnerablePackage",
              "vulnerableVersions",
              "targetVersion",
              "strategy",
              "riskLevel",
              "complexity",
              "implementation",
              "verification",
              "outcome"
            ],
            "properties": {
              "vulnerableVersions": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "minItems": 1
              },
              "complexity": {
                "type": "string",
                "enum": ["contained", "architectural"]
              },
              "implementation": {
                "type": "object",
                "required": ["filesChanged"]
              },
              "verification": {
                "type": "object",
                "required": ["dependencyCheck", "lint", "typecheck", "tests", "build"]
              },
              "outcome": {
                "type": "object",
                "required": ["result", "summary"]
              }
            },
            "not": {
              "anyOf": [
                { "required": ["filePath"] },
                { "required": ["lineRange"] },
                { "required": ["cweId"] }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "issueType": { "const": "package_vulnerability" },
              "status": { "const": "resolved" }
            },
            "required": ["issueType", "status"]
          },
          "then": {
            "properties": {
              "verification": {
                "type": "object",
                "properties": {
                  "dependencyCheck": { "const": "pass" }
                }
              },
              "outcome": {
                "type": "object",
                "properties": {
                  "result": { "const": "resolved" }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "issueType": { "const": "package_vulnerability" },
              "status": { "const": "blocked" }
            },
            "required": ["issueType", "status"]
          },
          "then": {
            "properties": {
              "outcome": {
                "type": "object",
                "required": ["result", "summary", "blockers", "remediationProposal", "rationale"],
                "properties": {
                  "result": { "const": "blocked" },
                  "blockers": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "minItems": 1
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "issueType": { "const": "package_vulnerability" },
              "status": { "const": "partially-resolved" }
            },
            "required": ["issueType", "status"]
          },
          "then": {
            "properties": {
              "outcome": {
                "type": "object",
                "required": ["result", "summary", "blockers", "remediationProposal", "rationale"],
                "properties": {
                  "result": { "const": "partially-resolved" },
                  "blockers": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "minItems": 1
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "strategy": { "const": "temp-override" } },
            "required": ["strategy"]
          },
          "then": {
            "required": ["implementation"],
            "properties": {
              "implementation": {
                "type": "object",
                "required": ["overridesApplied", "overridePreflight"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "issueType": { "const": "code" },
              "status": { "const": "resolved" }
            },
            "required": ["issueType", "status"]
          },
          "then": {
            "required": [
              "filePath",
              "lineRange",
              "cweId",
              "severity",
              "complexity",
              "implementation",
              "verification",
              "outcome"
            ],
            "properties": {
              "complexity": {
                "type": "string",
                "enum": ["trivial", "contained"]
              },
              "implementation": {
                "type": "object",
                "required": ["filesChanged"]
              },
              "verification": {
                "type": "object",
                "required": ["lint", "typecheck", "tests"]
              },
              "outcome": {
                "type": "object",
                "required": ["result", "summary"],
                "properties": {
                  "result": { "const": "resolved" }
                }
              }
            },
            "not": {
              "anyOf": [
                { "required": ["vulnerablePackage"] },
                { "required": ["vulnerableVersions"] },
                { "required": ["targetVersion"] },
                { "required": ["strategy"] },
                { "required": ["riskLevel"] },
                {
                  "type": "object",
                  "properties": {
                    "verification": {
                      "type": "object",
                      "anyOf": [
                        { "type": "object", "required": ["dependencyCheck"] },
                        { "type": "object", "required": ["build"] }
                      ]
                    }
                  },
                  "required": ["verification"]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "issueType": { "const": "code" },
              "status": { "const": "blocked" }
            },
            "required": ["issueType", "status"]
          },
          "then": {
            "required": [
              "filePath",
              "lineRange",
              "cweId",
              "severity",
              "complexity",
              "outcome"
            ],
            "properties": {
              "complexity": {
                "type": "string",
                "enum": ["false-positive", "architectural"]
              },
              "outcome": {
                "type": "object",
                "required": ["result", "summary", "blockers", "remediationProposal", "rationale"],
                "properties": {
                  "result": { "const": "blocked" },
                  "blockers": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "minItems": 1
                  }
                }
              }
            },
            "not": {
              "anyOf": [
                { "required": ["vulnerablePackage"] },
                { "required": ["vulnerableVersions"] },
                { "required": ["targetVersion"] },
                { "required": ["strategy"] },
                { "required": ["riskLevel"] },
                { "required": ["implementation"] },
                { "required": ["verification"] }
              ]
            }
          }
        }
      ]
    }
  }
}
